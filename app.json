{
  "expo": {
    "name": "FAST//TRACK",
    "slug": "fast-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fasttrack",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#F2EFE8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fasttrack.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8291C"
      },
      "package": "com.fasttrack.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
